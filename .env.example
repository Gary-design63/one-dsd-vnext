# One DSD vNext — environment template (Layer 6)
# Copy to .env for local dev. In production these come from Azure Key Vault.
# NEVER commit real secrets.

NODE_ENV=development
PORT=8080

# Postgres (Azure Database for PostgreSQL Flexible Server in prod).
# The app connects as the least-privilege role one_dsd_app.
DATABASE_URL=postgres://one_dsd_app:CHANGE_ME@localhost:5432/one_dsd

# Session lifetimes (minutes)
SESSION_IDLE_MINUTES=60
SESSION_ABSOLUTE_MINUTES=720

# Cookie
SESSION_COOKIE=one_dsd_session
COOKIE_SECURE=false        # true in production (HTTPS)

# Login throttling
LOGIN_MAX_FAILURES=8
LOGIN_WINDOW_MINUTES=15
